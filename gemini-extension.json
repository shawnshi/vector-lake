{
  "name": "vector-lake",
  "version": "8.1.0",
  "description": "LLM-Wiki engine for long-term memory retrieval and semantic consolidation via pure Markdown knowledge graph.",
  "contextFileName": "CONTEXT.md",
  "entry_points": {
    "cli": "./cli.py",
    "ingest": "./vector_lake/ingest.py",
    "indexer": "./vector_lake/indexer.py",
    "watchdog": "./watchdog_sync.py",
    "review": "./vector_lake/review.py"
  },
  "runtime": {
    "recommended_cwd": "extensions/vector-lake/",
    "python_version": ">=3.10"
  },
  "excludeTools": [
    "run_shell_command(rm -rf *)",
    "run_shell_command(del /s /q *)"
  ]
}
